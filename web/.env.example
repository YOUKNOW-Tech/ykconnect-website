# Amplitude product-analytics API key (client-side, exposed to the browser —
# expected for Amplitude's browser SDK; it is not a secret).
# Get this from Amplitude -> Settings -> Projects -> [project] -> API Key.
# Vite only exposes client env vars prefixed VITE_, so the name below is required.
VITE_AMPLITUDE_API_KEY=

# --- HubSpot Forms API (server-side only, used by web/api/hubspot-contact.js) ---
# Read with process.env.* inside the Vercel serverless function, never exposed
# to the browser (no VITE_ prefix). `vite dev` does not read or need these —
# they only matter when the function actually runs (see README/local testing
# notes; use `vercel dev` to exercise this locally).
#
# Portal ID: Settings (gear icon) -> Account Setup -> Account Defaults in
# HubSpot, also visible in the URL of any app.hubspot.com/.../<portalId>/... page.
# Form GUID: Marketing/Forms -> select the form -> editor URL is
# app.hubspot.com/forms/<portalId>/<formGuid>/edit.
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=
